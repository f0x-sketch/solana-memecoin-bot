# Autoresearch Solana - Configuration

# === Solana RPC ===
# Use Helius, QuickNode, or your own RPC for best performance
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WSS_URL=wss://api.mainnet-beta.solana.com

# === Wallet ===
# Base58 encoded private key for trading
# For paper trading, any valid key works (funds not used)
SOLANA_PRIVATE_KEY=your_base58_private_key_here

# === Jupiter API (for swaps) ===
JUPITER_API_KEY=your_jupiter_api_key_here

# === Mode ===
# DRY_RUN=true: Paper trading - simulates trades, no real money
# DRY_RUN=false: Live trading - real money at risk
DRY_RUN=true

# === Initial Capital ===
# Amount to trade with (in USDC)
INITIAL_CAPITAL_USD=1000
MAX_POSITION_SIZE_USD=500
MIN_TRADE_SIZE_USD=50

# === Risk Parameters ===
MAX_DAILY_LOSS_PCT=5
MAX_POSITIONS=5
STOP_LOSS_PCT=3
TAKE_PROFIT_PCT=6

# === Research Parameters ===
# How often to run new experiments (hours)
EXPERIMENT_INTERVAL_HOURS=6
# Number of experiments to run before promoting to live
MIN_EXPERIMENTS_BEFORE_LIVE=10
# Minimum win rate to promote strategy
MIN_WIN_RATE_PCT=55
# Minimum Sharpe ratio
MIN_SHARPE_RATIO=1.2

# === Strategy Parameters ===
# These will be auto-optimized by the research loop
INITIAL_PROFIT_THRESHOLD=0.02
INITIAL_HOLD_TIME_MINUTES=60
INITIAL_MOMENTUM_PERIOD=14

# === Database ===
DATABASE_PATH=./data/trades.db

# === Logging ===
LOG_LEVEL=info
